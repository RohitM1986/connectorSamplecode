<?xml version="1.0" encoding="utf-8"?>
<AxTable xmlns:i="http://www.w3.org/2001/XMLSchema-instance">
  <Name>CRMIntegrationLog</Name>
  <Label>CRM Integration Log</Label>
  <TableGroup>TransactionHeader</TableGroup>
  <TitleField1>RequestId</TitleField1>
  <TitleField2>RequestTimestamp</TitleField2>
  <PrimaryIndex>RecIdIdx</PrimaryIndex>
  <SaveDataPerCompany>Yes</SaveDataPerCompany>
  <Fields>
    <AxTableField>
      <Name>RecId</Name>
      <Type>Int64</Type>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>RequestId</Name>
      <ExtendedDataType>String50</ExtendedDataType>
      <Label>Request ID</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>RequestTimestamp</Name>
      <ExtendedDataType>CreatedDateTime</ExtendedDataType>
      <Label>Request Time</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>ResponseTimestamp</Name>
      <ExtendedDataType>ModifiedDateTime</ExtendedDataType>
      <Label>Response Time</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>TransactionId</Name>
      <ExtendedDataType>String50</ExtendedDataType>
      <Label>Transaction ID</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>AccountCount</Name>
      <ExtendedDataType>Integer</ExtendedDataType>
      <Label>Account Count</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>ProcessedRecords</Name>
      <ExtendedDataType>Integer</ExtendedDataType>
      <Label>Processed</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>FailedRecords</Name>
      <ExtendedDataType>Integer</ExtendedDataType>
      <Label>Failed</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>Status</Name>
      <ExtendedDataType>String20</ExtendedDataType>
      <Label>Status</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>Success</Name>
      <ExtendedDataType>NoYes</ExtendedDataType>
      <Label>Success</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>ErrorMessage</Name>
      <ExtendedDataType>String1000</ExtendedDataType>
      <Label>Error Message</Label>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>CreatedDateTime</Name>
      <ExtendedDataType>CreatedDateTime</ExtendedDataType>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
    <AxTableField>
      <Name>CreatedBy</Name>
      <ExtendedDataType>CreatedBy</ExtendedDataType>
      <AllowEdit>No</AllowEdit>
    </AxTableField>
  </Fields>
  <Indexes>
    <AxTableIndex>
      <Name>RecIdIdx</Name>
      <AlternateKey>No</AlternateKey>
      <Fields>
        <AxTableIndexField>
          <DataField>RecId</DataField>
        </AxTableIndexField>
      </Fields>
    </AxTableIndex>
    <AxTableIndex>
      <Name>RequestIdIdx</Name>
      <AlternateKey>Yes</AlternateKey>
      <AllowDuplicates>No</AllowDuplicates>
      <Fields>
        <AxTableIndexField>
          <DataField>RequestId</DataField>
        </AxTableIndexField>
      </Fields>
    </AxTableIndex>
    <AxTableIndex>
      <Name>RequestTimestampIdx</Name>
      <Fields>
        <AxTableIndexField>
          <DataField>RequestTimestamp</DataField>
        </AxTableIndexField>
      </Fields>
    </AxTableIndex>
  </Indexes>
</AxTable>
