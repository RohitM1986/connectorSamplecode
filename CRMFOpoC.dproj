  </ItemGroup>

  <Import Project="$(VSToolsPath)\Dynamics\Microsoft.Dynamics.Framework.Tools.Project.Extensibility.Targets" Condition="Exists('$(VSToolsPath)\Dynamics\Microsoft.Dynamics.Framework.Tools.Project.Extensibility.Targets')" />
